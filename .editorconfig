# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# C# files
[*.cs]
# IDE code style rules
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Naming conventions
dotnet_naming_rule.interface_should_be_begins_with_i.severity = warning
dotnet_naming_rule.interface_should_be_begins_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begins_with_i.style = begins_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal

dotnet_naming_symbols.private_field.applicable_kinds = field
dotnet_naming_symbols.private_field.applicable_accessibilities = private
dotnet_naming_symbols.private_field.required_modifiers =

dotnet_naming_rule.private_field_should_be_camel_case.severity = warning
dotnet_naming_rule.private_field_should_be_camel_case.symbols = private_field
dotnet_naming_rule.private_field_should_be_camel_case.style = camel_case

dotnet_naming_rule.types_should_be_pascal_case.severity = warning
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case

dotnet_naming_symbols.types.applicable_kinds = class, struct, enum, delegate, event
dotnet_naming_symbols.types.applicable_accessibilities = public, internal

# Blazor/Razor files
[*.razor]
indent_size = 4

# XML files
[*.{csproj,props,targets,resx}]
indent_size = 2

# Solution files
[*.sln*]
indent_size = 2

###############################################################################
# .NET Code Quality Rules
# https://docs.microsoft.com/dotnet/fundamentals/code-analysis/quality-rules/
###############################################################################

# Design Rules - suggest over error for cleaner builds
CA1062 = suggestion   # Validate arguments of public methods
CA1063 = warning     # Implement IDisposable correctly
CA1064 = warning     # C# exceptions should be public

# Performance Rules
CA1805 = warning   # Do not initialize unnecessarily
CA1806 = warning   # Do not ignore method results
CA1812 = warning   # Avoid uninstantiated internal classes
CA1822 = suggestion # Mark members as static

# Security Rules
CA2007 = none     # Do not directly await a Task (use ConfigureAwait)
CA5361 = warning  # Do not use SChannel encryption
CA5386 = warning  # Avoid hardcoded SecurityProtocolType values

# Usage Rules
CA1062 = suggestion  # Validate arguments
CA2000 = warning  # Dispose objects before losing scope
CA2200 = warning  # Rethrow to preserve stack details

# Documentation Rules
CA1200 = warning  # Avoid using cref tags with a prefix
CA1201 = warning  # Do not mix types in a namespace

# Maintainability Rules
CA1501 = warning  # Avoid excessive inheritance
CA1502 = warning  # Avoid excessive complexity
CA1505 = warning  # Avoid unmaintainable code
CA1506 = warning  # Avoid excessive class coupling
CA1507 = suggestion # Use nameof() in attribute arguments

# Naming Rules
CA1707 = warning  # Identifiers should not contain underscores
CA1710 = warning  # Identifiers should have correct suffix
CA1711 = warning  # Identifiers should not end with incorrect suffix
CA1712 = warning  # Do not prefix enum values with type name
CA1713 = warning  # Do not prefix events with a verb
CA1714 = warning  # Flags enums should have plural names
CA1715 = warning  # Identifiers should have correct prefix
CA1716 = warning  # Do not use reserved keywords in namespace
CA1717 = warning  # Only FlagsAttribute enums should have plural names
CA1720 = warning  # Do not use type names in parameter names
CA1721 = warning  # Conflicting property names
CA1724 = warning  # Do not type name conflicts with System namespaces

# Compilation Suppressions (for generated code and migrations)
[**/Migrations/**/*.cs]
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1507.severity = none
dotnet_diagnostic.CA1822.severity = none

[**/obj/**/*.cs]
dotnet_analyzer_diagnostic.severity = none

[**/bin/**/*.cs]
dotnet_analyzer_diagnostic.severity = none