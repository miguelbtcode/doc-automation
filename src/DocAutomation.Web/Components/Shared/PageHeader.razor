@namespace DocAutomation.Web.Components.Shared

<div class="da-page-header rz-mb-4">
    @if (Breadcrumbs is not null && Breadcrumbs.Any())
    {
        <RadzenBreadCrumb Class="rz-mb-2">
            <RadzenBreadCrumbItem Path="/" Text="Inicio" />
            @foreach (var crumb in Breadcrumbs)
            {
                <RadzenBreadCrumbItem Path="@crumb.Path" Text="@crumb.Text" />
            }
        </RadzenBreadCrumb>
    }

    <div class="da-page-header-bar">
        <div class="da-page-header-title">
            @if (BackPath is not null)
            {
                <RadzenButton Icon="arrow_back" Variant="Variant.Text" Size="ButtonSize.Medium"
                              Click="@(() => Nav.NavigateTo(BackPath))" />
            }
            <div>
                <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Class="rz-m-0">@Title</RadzenText>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">
                        @Subtitle
                    </RadzenText>
                }
            </div>
            @if (TitleBadges is not null)
            {
                @TitleBadges
            }
        </div>

        @if (Actions is not null)
        {
            <div class="da-page-header-actions">
                @Actions
            </div>
        }
    </div>
</div>

@code {
    [Inject] private NavigationManager Nav { get; set; } = null!;

    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public string? BackPath { get; set; }
    [Parameter] public List<BreadcrumbItem>? Breadcrumbs { get; set; }
    [Parameter] public RenderFragment? TitleBadges { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    public record BreadcrumbItem(string Text, string? Path = null);
}
