@namespace DocAutomation.Web.Components.Shared
@using DocAutomation.Domain.Enums

<RadzenTabs TabPosition="TabPosition.Top" RenderMode="TabRenderMode.Client">
    <Tabs>
        <RadzenTabsItem Text="@($"Pasos Principales ({Model.MainSteps.Count})")">
            <div class="rz-p-4">
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem;">
                    Definí los pasos de la sección principal. Cada paso debe tener un título y una descripción detallada.
                </RadzenText>

                @foreach (var step in Model.MainSteps)
                {
                    <StepEditCard @key="step.Id" Step="step" Position="@(Model.MainSteps.IndexOf(step) + 1)"
                                  TotalCount="@Model.MainSteps.Count" AllowVerification="true"
                                  OnMoveUp="() => MoveUp(Model.MainSteps, step)"
                                  OnMoveDown="() => MoveDown(Model.MainSteps, step)"
                                  OnDelete="() => Delete(Model.MainSteps, step)" />
                }

                <RadzenButton Text="Agregar paso" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Variant="Variant.Outlined" Click="@(() => AddStep(Model.MainSteps))" />
            </div>
        </RadzenTabsItem>
        <RadzenTabsItem Text="@($"Post-Pase ({Model.PostSteps.Count})")">
            <div class="rz-p-4">
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem;">
                    Definí los pasos de la sección post-pase. Cada paso debe tener un título y una descripción detallada.
                </RadzenText>

                @foreach (var step in Model.PostSteps)
                {
                    <StepEditCard @key="step.Id" Step="step" Position="@(Model.PostSteps.IndexOf(step) + 1)"
                                  TotalCount="@Model.PostSteps.Count" AllowVerification="false"
                                  OnMoveUp="() => MoveUp(Model.PostSteps, step)"
                                  OnMoveDown="() => MoveDown(Model.PostSteps, step)"
                                  OnDelete="() => Delete(Model.PostSteps, step)" />
                }

                <RadzenButton Text="Agregar paso" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Variant="Variant.Outlined" Click="@(() => AddStep(Model.PostSteps))" />
            </div>
        </RadzenTabsItem>
        <RadzenTabsItem Text="@($"Reversión ({Model.ReversionSteps.Count})")">
            <div class="rz-p-4">
                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color); margin-bottom: 1rem;">
                    Definí los pasos de la sección reversión. Cada paso debe tener un título y una descripción detallada.
                </RadzenText>

                @foreach (var step in Model.ReversionSteps)
                {
                    <StepEditCard @key="step.Id" Step="step" Position="@(Model.ReversionSteps.IndexOf(step) + 1)"
                                  TotalCount="@Model.ReversionSteps.Count" AllowVerification="true"
                                  OnMoveUp="() => MoveUp(Model.ReversionSteps, step)"
                                  OnMoveDown="() => MoveDown(Model.ReversionSteps, step)"
                                  OnDelete="() => Delete(Model.ReversionSteps, step)" />
                }

                <RadzenButton Text="Agregar paso" Icon="add" ButtonStyle="ButtonStyle.Primary"
                              Variant="Variant.Outlined" Click="@(() => AddStep(Model.ReversionSteps))" />
            </div>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    [Parameter, EditorRequired] public StepsEditorModel Model { get; set; } = null!;

    private void AddStep(List<StepEditModel> steps)
    {
        steps.Add(new StepEditModel
        {
            Order = steps.Count + 1,
            Type = StepType.Action
        });
        StateHasChanged();
    }

    private void Delete(List<StepEditModel> steps, StepEditModel step)
    {
        steps.Remove(step);
        StateHasChanged();
    }

    private void MoveUp(List<StepEditModel> steps, StepEditModel step)
    {
        var idx = steps.IndexOf(step);
        if (idx > 0)
        {
            steps.RemoveAt(idx);
            steps.Insert(idx - 1, step);
            StateHasChanged();
        }
    }

    private void MoveDown(List<StepEditModel> steps, StepEditModel step)
    {
        var idx = steps.IndexOf(step);
        if (idx >= 0 && idx < steps.Count - 1)
        {
            steps.RemoveAt(idx);
            steps.Insert(idx + 1, step);
            StateHasChanged();
        }
    }
}
