@namespace DocAutomation.Web.Components.Shared
@using DocAutomation.Domain.Enums

<RadzenTabs TabPosition="TabPosition.Top" RenderMode="TabRenderMode.Client">
    <Tabs>
        <RadzenTabsItem Text="@($"Pasos Principales ({Model.MainSteps.Count})")">
            @RenderSectionEditor(Model.MainSteps, "principal", allowVerification: true)
        </RadzenTabsItem>
        <RadzenTabsItem Text="@($"Post-Pase ({Model.PostSteps.Count})")">
            @RenderSectionEditor(Model.PostSteps, "post-pase", allowVerification: false)
        </RadzenTabsItem>
        <RadzenTabsItem Text="@($"Reversión ({Model.ReversionSteps.Count})")">
            @RenderSectionEditor(Model.ReversionSteps, "reversión", allowVerification: true)
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    [Parameter, EditorRequired] public StepsEditorModel Model { get; set; } = null!;

    private RenderFragment RenderSectionEditor(List<StepEditModel> steps, string sectionLabel, bool allowVerification) => builder =>
    {
        var seq = 0;

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "rz-p-4");

        builder.OpenComponent<RadzenText>(seq++);
        builder.AddAttribute(seq++, "TextStyle", TextStyle.Body2);
        builder.AddAttribute(seq++, "Style", "color: var(--rz-text-secondary-color); margin-bottom: 1rem;");
        builder.AddAttribute(seq++, "ChildContent", (RenderFragment)(t => t.AddContent(0,
            $"Definí los pasos de la sección {sectionLabel}. Cada paso debe tener un título y una descripción detallada.")));
        builder.CloseComponent();

        var index = 0;
        foreach (var step in steps.ToList())
        {
            index++;
            var captured = step;
            var capturedIndex = index;
            builder.OpenComponent<StepEditCard>(seq++);
            builder.AddAttribute(seq++, "Step", captured);
            builder.AddAttribute(seq++, "Position", capturedIndex);
            builder.AddAttribute(seq++, "TotalCount", steps.Count);
            builder.AddAttribute(seq++, "AllowVerification", allowVerification);
            builder.AddAttribute(seq++, "OnMoveUp", EventCallback.Factory.Create(this, () => MoveUp(steps, captured)));
            builder.AddAttribute(seq++, "OnMoveDown", EventCallback.Factory.Create(this, () => MoveDown(steps, captured)));
            builder.AddAttribute(seq++, "OnDelete", EventCallback.Factory.Create(this, () => Delete(steps, captured)));
            builder.SetKey(captured.Id);
            builder.CloseComponent();
        }

        builder.OpenComponent<RadzenButton>(seq++);
        builder.AddAttribute(seq++, "Text", "Agregar paso");
        builder.AddAttribute(seq++, "Icon", "add");
        builder.AddAttribute(seq++, "ButtonStyle", ButtonStyle.Primary);
        builder.AddAttribute(seq++, "Variant", Variant.Outlined);
        builder.AddAttribute(seq++, "Click", EventCallback.Factory.Create(this, () => AddStep(steps)));
        builder.CloseComponent();

        builder.CloseElement();
    };

    private void AddStep(List<StepEditModel> steps)
    {
        steps.Add(new StepEditModel
        {
            Order = steps.Count + 1,
            Type = StepType.Action
        });
        StateHasChanged();
    }

    private void Delete(List<StepEditModel> steps, StepEditModel step)
    {
        steps.Remove(step);
        StateHasChanged();
    }

    private void MoveUp(List<StepEditModel> steps, StepEditModel step)
    {
        var idx = steps.IndexOf(step);
        if (idx > 0)
        {
            steps.RemoveAt(idx);
            steps.Insert(idx - 1, step);
            StateHasChanged();
        }
    }

    private void MoveDown(List<StepEditModel> steps, StepEditModel step)
    {
        var idx = steps.IndexOf(step);
        if (idx >= 0 && idx < steps.Count - 1)
        {
            steps.RemoveAt(idx);
            steps.Insert(idx + 1, step);
            StateHasChanged();
        }
    }
}
