@namespace DocAutomation.Web.Components.Shared
@using DocAutomation.Application.Features.Templates.Models
@using DocAutomation.Domain.Enums

<RadzenFormField Text="@(Input.Label + (Input.IsRequired ? " *" : ""))" Variant="Variant.Outlined" Style="width: 100%;">
    @if (Input.InputType == InputType.Boolean)
    {
        <RadzenSwitch Value="_boolValue" ValueChanged="@(EventCallback.Factory.Create<bool>(this, OnBoolChanged))" />
    }
    else if (Input.InputType == InputType.Number)
    {
        <RadzenNumeric Value="_decimalValue" ValueChanged="@(EventCallback.Factory.Create<decimal>(this, OnDecimalChanged))" ShowUpDown="false" />
    }
    else if (Input.InputType == InputType.Date)
    {
        <RadzenDatePicker Value="_dateValue" ValueChanged="@(EventCallback.Factory.Create<DateTime?>(this, OnDateChanged))" />
    }
    else
    {
        <RadzenTextBox Value="@_stringValue" ValueChanged="@(EventCallback.Factory.Create<string>(this, OnStringChanged))" />
    }
</RadzenFormField>

@code {
    [Parameter, EditorRequired] public TemplateInputDto Input { get; set; } = null!;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private bool _boolValue;
    private decimal _decimalValue;
    private DateTime? _dateValue;
    private string _stringValue = string.Empty;

    protected override void OnParametersSet()
    {
        // Always sync from parent when Value changes
        _boolValue = string.Equals(Value, "true", StringComparison.OrdinalIgnoreCase);
        _decimalValue = decimal.TryParse(Value, out var n) ? n : 0m;
        _dateValue = DateTime.TryParse(Value, out var d) ? d : null;
        _stringValue = Value ?? string.Empty;
    }

    private async Task OnBoolChanged(bool v)
    {
        _boolValue = v;
        await ValueChanged.InvokeAsync(v.ToString().ToLowerInvariant());
    }

    private async Task OnDecimalChanged(decimal v)
    {
        _decimalValue = v;
        await ValueChanged.InvokeAsync(v.ToString());
    }

    private async Task OnDateChanged(DateTime? v)
    {
        _dateValue = v;
        await ValueChanged.InvokeAsync(v?.ToString("yyyy-MM-dd") ?? "");
    }

    private async Task OnStringChanged(string v)
    {
        _stringValue = v ?? string.Empty;
        await ValueChanged.InvokeAsync(v ?? "");
    }
}