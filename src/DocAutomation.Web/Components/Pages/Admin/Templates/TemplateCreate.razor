@page "/admin/templates/create"
@page "/admin/work-orders/templates/create"
@using DocAutomation.Application.Features.Templates.Commands.CreateTemplate
@using DocAutomation.Application.Common.Cqrs
@using DocAutomation.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager Nav
@inject NotificationService NotificationService
@inject KeyboardShortcutService Shortcuts
@inject UnsavedChangesGuard Guard
@inject RecentActionsService RecentActions
@implements IDisposable

<PageTitle>Nuevo Template</PageTitle>

<PageHeader Title="Nuevo Template"
            BackPath="@ListPath"
            Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new("Administración"), new(ListLabel, ListPath), new("Nuevo") })">
    <Actions>
        <RadzenButton Text="Cancelar" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Base"
                      Click="@(() => Nav.NavigateTo(ListPath))" />
        <RadzenButton Text="@(_saving ? "Guardando..." : "Crear Template (Ctrl+S)")" Icon="save"
                      ButtonStyle="ButtonStyle.Primary" Disabled="_saving" Click="@(() => SaveAsync())" />
    </Actions>
</PageHeader>

<RadzenCard Variant="Variant.Outlined" Class="rz-p-6">
    @if (_isWorkOrders)
    {
        <WorkOrderTemplateForm @ref="_woForm" Model="_model" />
    }
    else
    {
        <TemplateForm @ref="_templateForm" Model="_model" />
    }
</RadzenCard>

@code {
    private readonly TemplateFormModel _model = new();
    private TemplateForm _templateForm = null!;
    private WorkOrderTemplateForm _woForm = null!;
    private bool _saving;
    private bool _isWorkOrders;

    private TemplateType TemplateType => _isWorkOrders ? TemplateType.WorkOrder : TemplateType.Deployment;
    private string ListPath => _isWorkOrders ? "/admin/work-orders/templates" : "/admin/templates";
    private string ListLabel => _isWorkOrders ? "Templates WO" : "Templates";
    private string PreviewBasePath => _isWorkOrders ? "/admin/work-orders/templates" : "/admin/templates";

    protected override void OnInitialized()
    {
        _isWorkOrders = Nav.Uri.Contains("/work-orders/");
        Shortcuts.ShortcutTriggered += OnShortcutAsync;
    }

    private Task OnShortcutAsync(string key) => key == "ctrl+s" ? SaveAsync() : Task.CompletedTask;

    private async Task SaveAsync()
    {
        if (_saving) return;

        if (_isWorkOrders)
        {
            if (!_woForm.Validate())
            {
                NotificationService.Notify(NotificationSeverity.Warning,
                    "Completá todos los campos",
                    "Nombre, slug, al menos una variable y el contenido son requeridos.");
                return;
            }
        }
        else if (!await _templateForm.ValidateAsync())
        {
            NotificationService.Notify(NotificationSeverity.Warning,
                "Completá todos los campos",
                "Todos los pasos deben tener título y descripción.");
            return;
        }

        _saving = true;
        try
        {
            var stepsJson = _isWorkOrders
                ? StepsJsonConverter.WoContentToJson(_model.WoContent)
                : StepsJsonConverter.ToJson(_model.Steps);

            var id = await Mediator.Send(new CreateTemplateCommand(
                _model.Slug,
                _model.Name,
                _model.Description,
                stepsJson,
                _model.Inputs,
                "admin",
                TemplateType));

            await Guard.MarkCleanAsync();
            NotificationService.Notify(NotificationSeverity.Success, "Template creado correctamente.");
            await RecentActions.LogAsync($"Template creado: {_model.Name}",
                detail: _model.Slug,
                severity: RecentActionSeverity.Success,
                href: $"{PreviewBasePath}/preview/{id}");
            Nav.NavigateTo($"{PreviewBasePath}/preview/{id}");
        }
        catch (FluentValidation.ValidationException ex)
        {
            foreach (var err in ex.Errors)
                NotificationService.Notify(NotificationSeverity.Error, err.ErrorMessage);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        Shortcuts.ShortcutTriggered -= OnShortcutAsync;
        _ = Guard.MarkCleanAsync();
    }
}
