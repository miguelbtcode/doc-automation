@page "/deployments/history"
@page "/work-orders/history"
@using DocAutomation.Application.Features.Deployments.Queries.GetAllDeployments
@using DocAutomation.Application.Features.Templates.Models
@using DocAutomation.Application.Features.Deployments.Models
@using DocAutomation.Domain.Enums
@using DocAutomation.Application.Common.Cqrs
@inject IMediator Mediator
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@PageTitle</PageTitle>

<PageHeader Title="@PageTitle"
            Subtitle="@Subtitle"
            Breadcrumbs="@(new List<PageHeader.BreadcrumbItem> { new(SectionLabel), new("Historial") })">
    <Actions>
        <RadzenButton Text="@NewBtnLabel" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => Nav.NavigateTo(NewPath))" />
    </Actions>
</PageHeader>

<RadzenDataGrid Data="@_deployments" TItem="DeploymentListItemDto" IsLoading="@_loading"
                AllowPaging="true" PageSize="20" AllowSorting="true" AllowFiltering="true"
                Density="Density.Compact" Virtualization="true">
    <Columns>
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="TemplateName" Title="Template" />
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="TemplateVersion" Title="Versión" Width="100px" />
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="Status" Title="Estado" Width="140px">
            <Template Context="d">
                <RadzenBadge BadgeStyle="@StatusBadge(d.Status)" Text="@d.Status.ToString()" />
            </Template>
        </RadzenDataGridColumn>
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="CompletedBy" Title="Operador" />
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="StartedAt" Title="Inicio" FormatString="{0:yyyy-MM-dd HH:mm}" Width="170px" />
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Property="DurationMinutes" Title="Duración (min)" Width="140px" />
        <RadzenDataGridColumn TItem="DeploymentListItemDto" Title="" Width="80px" Sortable="false" Filterable="false">
            <Template Context="d">
                <RadzenButton Icon="visibility" Variant="Variant.Text" Size="ButtonSize.Small"
                              Click="@(() => Nav.NavigateTo($"{DetailBasePath}/{d.Id}"))" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
    <EmptyTemplate>
        <RadzenText Class="rz-p-4">Todavía no se generaron MVPs.</RadzenText>
    </EmptyTemplate>
</RadzenDataGrid>

@code {
    private IReadOnlyList<DeploymentListItemDto> _deployments = Array.Empty<DeploymentListItemDto>();
    private bool _loading = true;
    private bool _isWorkOrders;

    private TemplateType SectionType => _isWorkOrders ? TemplateType.WorkOrder : TemplateType.Deployment;
    private string PageTitle => _isWorkOrders ? "Historial de Work Orders" : "Historial de Pases";
    private string Subtitle => _isWorkOrders
        ? "Todas las Work Orders generadas"
        : "Todos los MVPs generados a partir de templates";
    private string SectionLabel => _isWorkOrders ? "Work Orders" : "Pases";
    private string NewPath => _isWorkOrders ? "/work-orders/new" : "/deployments/new";
    private string NewBtnLabel => _isWorkOrders ? "Nueva WO" : "Nuevo Pase";
    private string DetailBasePath => _isWorkOrders ? "/work-orders" : "/deployments";

    protected override async Task OnInitializedAsync()
    {
        _isWorkOrders = Nav.Uri.Contains("/work-orders/");
        Nav.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var isWorkOrders = e.Location.Contains("/work-orders/");
        if (isWorkOrders == _isWorkOrders) return;

        _isWorkOrders = isWorkOrders;
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _deployments = await Mediator.Send(new GetAllDeploymentsQuery(SectionType));
        _loading = false;
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private static BadgeStyle StatusBadge(DeploymentStatus status) => status switch
    {
        DeploymentStatus.Completed => BadgeStyle.Success,
        DeploymentStatus.Failed => BadgeStyle.Danger,
        DeploymentStatus.Reverted => BadgeStyle.Warning,
        _ => BadgeStyle.Info
    };
}
